@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

' Убираем стандартные легенды, если нужно
LAYOUT_WITH_LEGEND()

title Диаграмма контекста — Умный дом (расширение для собственников)

' === ЛЮДИ (ПОЛЬЗОВАТЕЛИ) ===
Person(owner, "Собственник", "Житель ЖК, использует мобильное приложение для управления Умным домом")
Person(uk_manager, "Менеджер УК", "Управляющая компания, администрирует доступ (внесение номеров/лиц)")

' === СУЩЕСТВУЮЩИЕ СИСТЕМЫ PROpDEVELOPMENT (КОНТЕКСТ) ===
System_Boundary(propdev, "PropDevelopment") {
    System(mobile_app, "Мобильное приложение собственников", "iOS / Android\nСуществующая витрина сервисов\n(оплата ЖКУ, информация, ремонт)")
    System(tenant_core, "tenant-core-app", "Бэкенд для предоставления услуг\nсобственникам (Kotlin, SpringBoot)")
    System(ad, "Active Directory / Keycloak", "Аутентификация и авторизация\nсобственников и сотрудников УК")
    System(crm, "CRM (данные собственников)", "Информация о собственниках,\nквартирах, доступе")
}

' === НОВАЯ ВНЕШНЯЯ СИСТЕМА ПАРТНЁРА ===
System_Ext(smarthome_api, "Smart Home API (Партнёр)", "Предоставляет сервисы:\n• Интеллектуальный домофон (биометрия)\n• Интеллектуальный шлагбаум (распознавание номеров)\nУправляется партнёром, не PropDevelopment")

' === ВНЕШНИЕ ПОЛЬЗОВАТЕЛИ/СИСТЕМЫ (для контекста) ===
Person(visitor, "Посетитель / Курьер", "Звонит в домофон, ожидает открытия")
System_Ext(auto_system, "Автомобиль с госномером", "Физический объект, номер распознаётся шлагбаумом")

' === СВЯЗИ ===

' Пользователи с мобильным приложением
Rel(owner, mobile_app, "Управляет доступом, просматривает события", "HTTPS")
Rel(uk_manager, mobile_app, "Администрирует список разрешённых\nномеров/лиц", "HTTPS")

' Мобильное приложение → Бэкенд
Rel(mobile_app, tenant_core, "Запросы на управление\nдоступом, получение событий", "REST/JSON")

' Бэкенд → Аутентификация
Rel(tenant_core, ad, "Проверка прав собственника,\nроль администратора УК", "LDAP/OAuth2")

' Бэкенд → CRM (получение данных владельца)
Rel(tenant_core, crm, "Получение списка\nквартир собственника,\nданных для доступа", "JDBC / REST")

' Бэкенд → Внешняя система партнёра (ключевая интеграция)
Rel(tenant_core, smarthome_api, "Синхронизация списка доступа\n(номера авто, биометрия лиц),\nзапрос событий\n(кто, когда вошёл)", "REST/HTTPS (tenant isolation required)")

' Внешние сущности с API партнёра (физические устройства опосредованно)
Rel(visitor, smarthome_api, "Звонок в домофон,\nпередача видео", "SIP / WebRTC")
Rel(auto_system, smarthome_api, "Распознавание номера,\nавтоматическое открытие", "Video / LPR")

' Дополнительно: собственник может получать push об открытии
Rel(owner, smarthome_api, "Получает уведомление\nоб открытии двери/шлагбаума", "Push через tenant_core")

@enduml